---
import SmoothScroll from '../components/SmoothScroll.astro'
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/perfil.png" type="image/png" />
    <meta
      name="description"
      content="Portafolio web de Juan Ramírez (JuanRCoder) - Conoce más sobre mí, mis habilidades en desarrollo web y mis proyectos destacados."
    />
    <meta
      property="og:url"
     content="https://juanrcoder.vercel.app/images/screen_shot_portfolio.png"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Portafolio web | HomePage" />
    <meta
      property="og:description"
      content="Portafolio web de Juan Ramírez (JuanRCoder) - Conoce más sobre mí, mis habilidades en desarrollo web y mis proyectos destacados."
    />
    <meta
      property="og:image"
     content="https://juanrcoder.vercel.app/images/screen_shot_portfolio.png"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:domain"
      content="juanrcoder.vercel.app"
    />
    <meta
      property="twitter:url"
      content="https://juanrcoder.vercel.app/"
    />
    <meta name="twitter:title" content="Portafolio web | HomePage" />
    <meta
      name="twitter:description"
      content="Portafolio web de Juan Ramírez (JuanRCoder) - Conoce más sobre mí, mis habilidades en desarrollo web y mis proyectos destacados."
    />
    <meta
      name="twitter:image"
      content="public/images/screen_shot_portfolio.png"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <title>Juan Ramirez - Portfolio</title>
  </head>
  <body class="relative hero-bg">
    <slot />
    <SmoothScroll />
  </body>
</html>
