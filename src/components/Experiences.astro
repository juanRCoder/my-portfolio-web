---
const experiences = [
  {
    role: "Desarrollador Full Stack (Plataforma de turnos)",
    company: "CT Developers",
    modality: "Remoto",
    period: "Febrero 2025 - Enero 2026",
    companyDescription:
      "Empresa de desarrollo de software que brinda soluciones tecnológicas a empresas de EE. UU.",
    description:
      "Responsable del desarrollo integral de una plataforma de turnos la cual maneja la asociación de rutas, vehículos y tipos de paquetes en turnos. Reconstruí un sistema de turnos lento (>2) migrándolo a una nueva arquitectura en (v3) que optimizó los tiempos de respuesta y simplificó la experiencia del usuario.",
  },
];
---

<article
  id="experience"
  class="container mx-auto max-w-6xl flex items-center justify-evenly gap-10 text-white py-20 px-4"
>
  <section class="w-full flex flex-col gap-8">
    <div class="flex items-center space-x-4">
      <h3 class="text-sm text-nowrap text-[#ADC6FF] tracking-wide">
        EXPERIENCIA LABORAL
      </h3>
      <div class="h-px w-full bg-[#ADC6FF4D]"></div>
    </div>
    
  <section class="w-full flex flex-col gap-4">
    {experiences.map(({ role, company, modality, period, companyDescription, description }) => (
      <div class="bg-[#1E293B]/40 border border-white/10 rounded-sm p-4">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <h3 class="text-slate-100 text-sm font-medium">{role}</h3>
          <span class="px-2.5 py-1 rounded-sm bg-[#FFFFFF]/3 text-[#4CD7F6] text-[11px] tracking-wide whitespace-nowrap">
            {period}
          </span>
        </div>

        <p class="text-slate-300 text-xs mt-1">
          {company} · {modality}
        </p>
        <p class="text-slate-400 text-xs mt-1">
          {companyDescription}
        </p>

        <p class="text-slate-300 text-sm mt-3 flex gap-2">
          <span class="text-[#ADC6FF] mt-0.5">▪</span>
          <span>{description}</span>
        </p>
      </div>
    ))}
  </section>
</article>