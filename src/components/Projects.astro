---
import { Image } from "astro:assets";

const NoImagen = "/images/no-imagen.jpg";
const Crewland = "/images/Crewland.png";
const CVinter = "/images/CVinter.png";

const projects = [
  {
    title: "CaveFlow",
    description:
      "Sistema de pedidos, MVP inicial para pequeños restaurantes, puestos de comida a la hora de solicitar pedidos en mesa o desde WhatsApp.",
    techs: ["REACT", "NESTJS", "POSTGRESQL"],
    image: NoImagen,
    link: "https://valnored.netlify.app/",
  },
  {
    title: "Crewland",
    description:
      "Plataforma de eventos para resolver el problema de alquiler de vivienda y transporte de fanáticos musicales a las giras de bandas.",
    techs: ["NEXT", "NESTJS", "POSTGRESQL"],
    image: Crewland,
    link: "https://event-crew-vibes.lovable.app/",
  },
  {
    title: "CVinter",
    description:
      "Generados de CV's para rellenar el CV en tiempo real con los datos del usuario usando html2canvas para la conversión.",
    techs: ["REACT", "TYPESCRIPT", "TAILWINDCSS"],
    image: CVinter,
    link: "https://i002-cvinter-front-phi.vercel.app/",
  },
];
---

<article
  class="container mx-auto max-w-6xl flex items-center justify-evenly gap-10 text-white py-20 px-4"
>
  <section class="w-full flex flex-col gap-8">
    <div class="flex items-center space-x-4">
      <h3 class="text-sm text-nowrap text-[#ADC6FF] tracking-wide">
        PROYECTOS DESTACADOS
      </h3>
      <div class="h-px w-full bg-[#ADC6FF4D]"></div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        projects.map((project) => (
          <div class="flex flex-col h-full bg-[#1E293B]/40 border border-[#334155]/50 rounded-sm transition-transform duration-300 hover:scale-102 cursor-pointer">
            <div class="h-52 rounded-t-sm">
              <Image
                class="w-full h-full object-container rounded-t-sm"
                src={project.image}
                alt={`photo_${project.title}`}
                loading="eager"
                width={208}
                height={208}
              />
            </div>
            <div class="flex-1 flex flex-col justify-start gap-2 p-2 pb-4">
              <p class="text-xl text-[#DFE2EF] font-semibold">{project.title}</p>
              <p class="text-[#94A3B8] text-sm line-clamp-3">{project.description}</p>
              <div class="flex gap-2 text-sm flex-wrap mt-4">
                {project.techs.map((tech) => (
                  <div class="bg-[#1C1F29]/50 border border-[#ADC6FF]/20 rounded-sm px-2 py-px">
                    <span class="text-[10px] text-[#C2C6D6] tracking-widest">
                      {tech}
                    </span>
                  </div>
                ))}
              </div>
            </div>
            <div class="flex gap-4 py-4 px-2 border-t border-[#334155]/50">
              {project.title === "CaveFlow" ? (
                <p class="text-[#ADC6FF]">En proceso</p>
              ) : (
                <a class="flex items-center gap-2 text-[#ADC6FF] hover:underline transition" href={project.link} target="_blank">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                    <path d="M10 13a5 5 0 0 0 7.07 0l2.83-2.83a5 5 0 0 0-7.07-7.07l-1.41 1.41" />
                    <path d="M14 11a5 5 0 0 0-7.07 0L4.1 13.83a5 5 0 0 0 7.07 7.07l1.41-1.41" />
                  </svg>
                  <span> Live Project</span>
                </a>
              )}

            </div>
          </div>
        ))
      }
    </div>
  </section>
</article>
